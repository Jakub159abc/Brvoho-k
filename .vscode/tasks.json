{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Články: přegenerovat rozcestník rostlin",
      "type": "shell",
      "command": "python",
      "args": ["_generate_clanky_rostliny_index.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Netlify: sestavit netlify-site",
      "type": "shell",
      "command": "python",
      "args": ["_build_netlify_site.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
